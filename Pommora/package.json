{
  "name": "pommora-react",
  "version": "0.0.1",
  "description": "Pommora — React + TypeScript + Electron rebuild (Phase 1: window + glass sidebar scaffold)",
  "main": "./out/main/index.js",
  "author": "Nathan Taichman",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "showcase": "vite",
    "build:showcase": "vite build",
    "dev:app": "vite -c vite.config.app.ts",
    "build:app": "vite build -c vite.config.app.ts",
    "package": "electron-vite build && electron-builder && npm rebuild better-sqlite3",
    "rebuild:electron": "electron-builder install-app-deps",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/write-file-atomic": "^4.0.3",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@samasante/liquid-glass": "^0.1.1",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "@types/better-sqlite3": "^7.6.13",
    "@vanilla-extract/css": "^1.20.1",
    "better-sqlite3": "^12.10.1",
    "chokidar": "^5.0.0",
    "lucide-react": "^1.18.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ulidx": "^2.4.1",
    "write-file-atomic": "^8.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
