{
  "name": "pommora-react",
  "version": "0.0.1",
  "description": "Pommora — React + TypeScript + Electron rebuild (Phase 1: window + glass sidebar scaffold)",
  "main": "./out/main/index.js",
  "author": "Nathan Taichman",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "liquid-glass-react": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  }
}
